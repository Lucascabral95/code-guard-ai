generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnalysisStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingType {
  TEST
  LINT
  SECURITY
  COVERAGE
  DEPENDENCY
  STACK_DETECTION
  SYSTEM
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model Analysis {
  id            String         @id @default(uuid())
  repoUrl       String
  branch        String         @default("main")
  status        AnalysisStatus
  riskScore     Int?
  riskLevel     RiskLevel?
  summary       String?
  detectedStack String?
  safeMode      Boolean
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?
  findings      Finding[]
  logs          AnalysisLog[]

  @@index([createdAt])
  @@index([status])
}

model Finding {
  id             String      @id @default(uuid())
  analysisId     String
  type           FindingType
  severity       Severity
  tool           String
  file           String?
  line           Int?
  message        String
  recommendation String?
  raw            Json?
  createdAt      DateTime    @default(now())
  analysis       Analysis    @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([severity])
}

model AnalysisLog {
  id         String   @id @default(uuid())
  analysisId String
  level      LogLevel
  message    String
  createdAt  DateTime @default(now())
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}
