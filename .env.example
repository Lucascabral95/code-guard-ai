POSTGRES_USER=codeguard
POSTGRES_PASSWORD=codeguard
POSTGRES_DB=codeguard
DATABASE_URL=postgresql://codeguard:codeguard@postgres:5432/codeguard

REDIS_ADDR=redis:6379
ANALYSIS_STREAM_NAME=scan.jobs

API_GATEWAY_PORT=3001
ANALYSIS_SERVICE_PORT=3002
ANALYSIS_SERVICE_URL=http://analysis-service:3002

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
SWAGGER_ENABLED=true
METRICS_ENABLED=true
METRICS_PATH=/metrics

INTERNAL_SECRET=dev-internal-secret
SAFE_ANALYSIS_MODE=true
SANDBOX_ANALYSIS_MODE=docker
TEMP_DIR=/tmp/codeguard
WORKER_METRICS_PORT=9101
SCANNER_TIMEOUT_SECONDS=120
SCANNER_OUTPUT_LIMIT_BYTES=10485760
SCANNER_DOCKER_NETWORK=none
SCANNER_SHARED_VOLUME=codeguard_scanner_workspace
SCANNER_WORKSPACE_PATH=/workspace
SCANNER_MEMORY_LIMIT=2g
SCANNER_CPU_LIMIT=2.0
SEMGREP_IMAGE=semgrep/semgrep:latest
TRIVY_IMAGE=aquasec/trivy:latest
OSV_SCANNER_IMAGE=ghcr.io/google/osv-scanner:latest
GITLEAKS_IMAGE=zricethezav/gitleaks:latest

OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOKI_PORT=3100
